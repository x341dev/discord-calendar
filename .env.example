# ─── Discord ─────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here
# Tu ID de usuario de Discord (activa Modo Desarrollador y clic derecho → Copiar ID)
DISCORD_USER_ID=your_discord_user_id

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Crea credenciales en https://console.cloud.google.com → APIs y servicios → Credenciales
# Tipo: Aplicación de escritorio
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
# Puerto local para el callback de OAuth durante el setup
GOOGLE_REDIRECT_PORT=3001

# ─── Configuración de calendarios ────────────────────────────────────────────
# Después de correr "bun run setup:auth", usa /calendars en Discord para ver los IDs

# Cuenta personal – calendarios que van al embed "Eventos del día"
# "El meu calendari" personal + diablescaldes@gmail.com
PERSONAL_EVENTS_CALENDAR_IDS=primary,diablescaldes@gmail.com

# Cuenta estudiante – "El meu calendari" con el horario de clases → embed "Horario"
STUDENT_SCHEDULE_CALENDAR_IDS=primary

# Cuenta estudiante – calendarios de Google Classroom (separados por coma)
# Déjalos vacíos para detección automática (nombre contiene "Classroom")
STUDENT_CLASSROOM_CALENDAR_IDS=

# ─── Programación ─────────────────────────────────────────────────────────────
TIMEZONE=Europe/Madrid
# Cron: 6:30 AM todos los días
SCHEDULE_CRON=30 6 * * *

# ─── Docker / Producción ──────────────────────────────────────────────────────
# Si el bot corre en un VPS o servidor remoto sin acceso al navegador local,
# activa este flag. Cambia el flujo de /auth para usar /auth-code manualmente.
# AUTH_REMOTE=true

# ─── Rutas de datos ───────────────────────────────────────────────────────────
TOKENS_PATH=./data/tokens.json
